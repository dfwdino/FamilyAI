@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject NavigationManager NavigationManager
@inject AuthStateService AuthStateService
@inject ProtectedLocalStorage Storage

<ul class="nav flex-column">
    <li class="nav-item">
        <a class="nav-link @IsActive("/admin")" href="/admin">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @IsActive("/admin/users")" href="/admin/users">
            <i class="bi bi-people"></i> Users
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @IsActive("/admin/roles")" href="/admin/roles">
            <i class="bi bi-shield-check"></i> Roles
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @IsActive("/admin/prompts")" href="/admin/prompts">
            <i class="bi bi-chat-square-text"></i> Prompts
        </a>
    </li>
</ul>

<div class="mt-auto pt-3">
    <button class="btn btn-outline-light btn-sm w-100" @onclick="Logout">
        <i class="bi bi-box-arrow-left me-1"></i> Log Out
    </button>
</div>

@code {
    private string IsActive(string path) =>
        NavigationManager.Uri.Contains(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    private async Task Logout()
    {
        await Storage.DeleteAsync("familyai_uid");
        AuthStateService.Logout();
        NavigationManager.NavigateTo("/", true);
    }
}
