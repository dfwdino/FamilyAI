@page "/admin"
@layout AdminLayout
@inject UserManagementService UserMgmt
@inject AuthStateService AuthStateService

<PageTitle>Admin Dashboard</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">Dashboard</h2>
        <small class="text-muted">Welcome back, @AuthStateService.CurrentUser?.Name</small>
    </div>
    <a class="btn btn-primary" href="/admin/users">
        <i class="bi bi-person-plus-fill me-1"></i> Manage Users
    </a>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-people-fill text-primary fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Users</div>
                    <div class="fs-2 fw-bold">@totalUsers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-emoji-smile-fill text-success fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Children</div>
                    <div class="fs-2 fw-bold">@totalChildren</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="bi bi-person-badge-fill text-info fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Parents</div>
                    <div class="fs-2 fw-bold">@totalParents</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h5 class="card-title mb-3">Quick Actions</h5>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-primary" href="/admin/users">
                <i class="bi bi-person-plus me-1"></i> Add a User
            </a>
            <a class="btn btn-outline-secondary" href="/admin/users">
                <i class="bi bi-link-45deg me-1"></i> Link Parents to Children
            </a>
        </div>
    </div>
</div>

@code {
    private int totalUsers, totalChildren, totalParents;

    protected override async Task OnInitializedAsync()
    {
        var users = await UserMgmt.GetAllUsersAsync();
        totalUsers    = users.Count;
        totalChildren = users.Count(u => u.RoleName == "Child");
        totalParents  = users.Count(u => u.RoleName == "Parent");
    }
}
