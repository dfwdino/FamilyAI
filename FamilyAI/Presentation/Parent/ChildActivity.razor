@page "/parent/child/{ChildId:int}"
@layout ParentLayout
@inject UserManagementService UserMgmt
@inject AuthStateService AuthStateService
@inject ThreadService ThreadSvc
@inject ChatLogService ChatLogSvc
@inject PromptSettingService PromptSvc
@inject NavigationManager NavigationManager

<PageTitle>Child Activity</PageTitle>

@if (childInfo == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="parent">My Children</a></li>
            <li class="breadcrumb-item active">@childInfo.Name</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center mb-4 gap-2">
        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center"
             style="width:48px;height:48px;">
            <i class="bi bi-person-fill text-primary fs-5"></i>
        </div>
        <div>
            <h4 class="mb-0 fw-semibold">@childInfo.Name's Conversations</h4>
            <small class="text-muted">@threads.Count conversation@(threads.Count == 1 ? "" : "s") — newest first</small>
        </div>
    </div>

    <!-- Prompt selector -->
    @if (allTemplates.Any())
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body d-flex align-items-center gap-3 py-3">
                <i class="bi bi-sliders text-primary fs-5"></i>
                <div class="flex-grow-1">
                    <div class="fw-semibold mb-1" style="font-size:0.9rem;">AI Learning Style</div>
                    <div class="d-flex align-items-center gap-2">
                        <select class="form-select form-select-sm" style="max-width:260px;"
                                value="@activeTemplateId"
                                @onchange="async e => await ChangePrompt(int.Parse(e.Value!.ToString()!))">
                            @foreach (var t in allTemplates)
                            {
                                <option value="@t.Id">@t.Name@(t.IsDefault ? " (default)" : "")</option>
                            }
                        </select>
                        @if (promptSaved)
                        {
                            <span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i>Saved</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(statusIsError ? "alert-danger" : "alert-success") alert-dismissible d-flex align-items-center gap-2 mb-3">
            <i class="bi @(statusIsError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i>
            @statusMessage
            <button type="button" class="btn-close ms-auto" @onclick='() => statusMessage = null'></button>
        </div>
    }

    @if (!threads.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-chat-slash text-muted" style="font-size:3rem; opacity:.3;"></i>
            <p class="mt-2 text-muted">No conversations yet.</p>
        </div>
    }
    else
    {
        @foreach (var thread in threads)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-chat-left-text text-primary"></i>
                        <strong>@thread.ThreadName</strong>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="() => ToggleThread(thread.Id)">
                            @if (expandedThreadId == thread.Id)
                            {
                                <i class="bi bi-chevron-up me-1"></i><span>Collapse</span>
                            }
                            else
                            {
                                <i class="bi bi-eye me-1"></i><span>View</span>
                            }
                        </button>
                        @if (confirmDeleteThreadId == thread.Id)
                        {
                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(thread.Id)">
                                <i class="bi bi-check-lg me-1"></i>Confirm Delete
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="CancelDelete">
                                Cancel
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => StartDelete(thread.Id)"
                                    title="Delete this conversation">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                    </div>
                </div>

                @if (expandedThreadId == thread.Id)
                {
                    <div class="card-body p-0">
                        <div style="max-height:400px;overflow-y:auto;background:#f8f9fa;padding:16px;">
                            @if (!threadMessages.Any())
                            {
                                <p class="text-muted mb-0">No messages.</p>
                            }
                            else
                            {
                                @foreach (var msg in threadMessages)
                                {
                                    <div class="d-flex mb-3 @(msg.IsReply ? "justify-content-start" : "justify-content-end")">
                                        @if (msg.IsReply)
                                        {
                                            <div class="me-2 mt-1">
                                                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center"
                                                     style="width:28px;height:28px;">
                                                    <i class="bi bi-robot text-white" style="font-size:.65rem;"></i>
                                                </div>
                                            </div>
                                            <div>
                                                <div style="background:#fff;border:1px solid #dee2e6;border-radius:12px 12px 12px 4px;padding:8px 12px;max-width:500px;">
                                                    @msg.Text
                                                </div>
                                                <div class="text-muted mt-1" style="font-size:0.7rem;">
                                                    @msg.EntryTime.ToLocalTime().ToString("g")
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-end">
                                                <div style="background:#0d6efd;color:#fff;border-radius:12px 12px 4px 12px;padding:8px 12px;max-width:500px;display:inline-block;">
                                                    @msg.Text
                                                </div>
                                                <div class="text-muted mt-1" style="font-size:0.7rem;">
                                                    @msg.EntryTime.ToLocalTime().ToString("g")
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }
}

@code {
    [Parameter] public int ChildId { get; set; }

    private UserDto? childInfo;
    private List<ThreadModel> threads = new();
    private List<ChatLog> threadMessages = new();
    private int expandedThreadId;
    private int confirmDeleteThreadId;
    private string? statusMessage;
    private bool statusIsError;

    private List<PromptTemplate> allTemplates = new();
    private int activeTemplateId;
    private bool promptSaved;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateService.CurrentUser == null) return;

        var myChildren = await UserMgmt.GetChildrenForParentAsync(AuthStateService.CurrentUser.UserId);
        childInfo = myChildren.FirstOrDefault(c => c.Id == ChildId);

        if (childInfo == null)
        {
            NavigationManager.NavigateTo("parent");
            return;
        }

        threads = ThreadSvc.GetAllThreadsByUser(ChildId);

        allTemplates = await PromptSvc.GetAllTemplatesAsync();
        activeTemplateId = await PromptSvc.GetActiveTemplateIdForUserAsync(ChildId);
        if (activeTemplateId == 0 && allTemplates.Any())
            activeTemplateId = allTemplates.FirstOrDefault(t => t.IsDefault)?.Id ?? allTemplates[0].Id;
    }

    private async Task ToggleThread(int threadId)
    {
        if (expandedThreadId == threadId)
        {
            expandedThreadId = 0;
            threadMessages = new();
            return;
        }

        expandedThreadId = threadId;
        threadMessages = await ChatLogSvc.GetChatLogsByThreadAsync(threadId);
    }

    private async Task ChangePrompt(int templateId)
    {
        try
        {
            activeTemplateId = templateId;
            await PromptSvc.SetActiveTemplateForUserAsync(ChildId, templateId);
            promptSaved = true;
            StateHasChanged();
            await Task.Delay(2000);
            promptSaved = false;
        }
        catch (Exception ex)
        {
            ShowStatus($"Error saving setting: {ex.Message}", true);
        }
    }

    private void StartDelete(int threadId)
    {
        confirmDeleteThreadId = threadId;
    }

    private void CancelDelete()
    {
        confirmDeleteThreadId = 0;
    }

    private async Task ConfirmDelete(int threadId)
    {
        try
        {
            if (expandedThreadId == threadId)
            {
                expandedThreadId = 0;
                threadMessages = new();
            }

            await ThreadSvc.DeleteThreadAsync(threadId);
            threads = ThreadSvc.GetAllThreadsByUser(ChildId);
            confirmDeleteThreadId = 0;
            statusMessage = "Conversation deleted.";
            statusIsError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Error deleting conversation: {ex.Message}";
            statusIsError = true;
            confirmDeleteThreadId = 0;
        }
    }

    private void ShowStatus(string msg, bool error = false)
    { statusMessage = msg; statusIsError = error; }
}
