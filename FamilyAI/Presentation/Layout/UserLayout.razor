@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager

<CascadingAuthenticationState>
<AuthorizeView Roles="Child">
    <Authorized>
        <div class="page-wrapper">
            <!-- Sidebar -->
            <div class="sidebar bg-dark d-flex flex-column p-3">
                <div class="mb-3 px-2">
                    <div class="text-white fw-bold fs-5">
                        <i class="bi bi-chat-dots-fill text-success"></i> FamilyAI
                    </div>
                    <small class="text-white-50">My Chats</small>
                </div>
                <a class="btn btn-success btn-sm mb-3"
                   href="/chat">
                    <i class="bi bi-plus-lg me-1"></i> New Chat
                </a>
                <div class="flex-grow-1 overflow-auto">
                    <FamilyAI.Presentation.User.Menu />
                </div>
            </div>

            <!-- Main content -->
            <div class="main-content bg-light">
                <div class="p-3 h-100">
                    @Body
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="d-flex justify-content-center align-items-center" style="min-height:100vh;">
            <div class="text-center">
                <i class="bi bi-lock-fill text-danger" style="font-size:3rem;"></i>
                <h3 class="mt-3">Access Denied</h3>
                <button class="btn btn-primary" @onclick='() => NavigationManager.NavigateTo("/")'>
                    <i class="bi bi-house-fill me-1"></i> Go Home
                </button>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
</CascadingAuthenticationState>
