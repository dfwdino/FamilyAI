@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager NavigationManager
@implements IDisposable

<CascadingAuthenticationState>
<AuthorizeView Roles="Child">
    <Authorized>
        <!-- Mobile header -->
        <div class="mobile-header bg-dark">
            <button class="btn btn-link text-white p-0" @onclick="ToggleSidebar">
                <i class="bi bi-list fs-3"></i>
            </button>
            <span class="text-white fw-bold">
                <i class="bi bi-chat-dots-fill text-success me-1"></i> FamilyAI
            </span>
            <a class="btn btn-success btn-sm ms-auto" href="chat">
                <i class="bi bi-plus-lg"></i> New
            </a>
        </div>

        <!-- Backdrop -->
        <div class="sidebar-backdrop @(_sidebarOpen ? "sidebar-open" : "")" @onclick="CloseSidebar"></div>

        <div class="page-wrapper">
            <!-- Sidebar -->
            <div class="sidebar bg-dark d-flex flex-column p-3 @(_sidebarOpen ? "sidebar-open" : "")">
                <div class="mb-3 px-2">
                    <div class="text-white fw-bold fs-5">
                        <i class="bi bi-chat-dots-fill text-success"></i> FamilyAI
                    </div>
                    <small class="text-white-50">My Chats</small>
                </div>
                <a class="btn btn-success btn-sm mb-3" href="chat">
                    <i class="bi bi-plus-lg me-1"></i> New Chat
                </a>
                <div class="flex-grow-1 overflow-auto">
                    <FamilyAI.Presentation.User.Menu />
                </div>
            </div>

            <!-- Main content -->
            <div class="main-content bg-light">
                <div class="p-3 h-100">
                    @Body
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="d-flex justify-content-center align-items-center" style="min-height:100vh;">
            <div class="text-center">
                <i class="bi bi-lock-fill text-danger" style="font-size:3rem;"></i>
                <h3 class="mt-3">Access Denied</h3>
                <button class="btn btn-primary" @onclick='() => NavigationManager.NavigateTo(NavigationManager.BaseUri)'>
                    <i class="bi bi-house-fill me-1"></i> Go Home
                </button>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
</CascadingAuthenticationState>

@code {
    private bool _sidebarOpen;

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
    private void CloseSidebar() => _sidebarOpen = false;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _sidebarOpen = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
