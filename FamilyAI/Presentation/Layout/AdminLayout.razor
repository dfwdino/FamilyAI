@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager

<CascadingAuthenticationState>
<AuthorizeView Roles="Admin">
    <Authorized>
        <div class="page-wrapper">
            <!-- Sidebar -->
            <div class="sidebar bg-dark d-flex flex-column p-3">
                <div class="mb-4 px-2">
                    <div class="text-white fw-bold fs-5">
                        <i class="bi bi-shield-lock-fill text-primary"></i> FamilyAI
                    </div>
                    <small class="text-white-50">Admin Panel</small>
                </div>
                <FamilyAI.Presentation.Admin.Menu />
            </div>

            <!-- Main content -->
            <div class="main-content bg-light">
                <div class="p-4">
                    @Body
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="d-flex justify-content-center align-items-center" style="min-height:100vh;">
            <div class="text-center">
                <i class="bi bi-lock-fill text-danger" style="font-size:3rem;"></i>
                <h3 class="mt-3">Access Denied</h3>
                <p class="text-muted">You need Admin privileges to access this page.</p>
                <button class="btn btn-primary" @onclick='() => NavigationManager.NavigateTo(NavigationManager.BaseUri)'>
                    <i class="bi bi-house-fill me-1"></i> Go Home
                </button>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
</CascadingAuthenticationState>
