@page "/chat"
@page "/chat/{ThreadId:int}"

@inject ChatLogService _chatLogService
@inject AIChatService _aiChatService
@inject PromptSettingService _promptSettingService
@inject PendingAiTracker _pendingTracker
@inject AuthStateService AuthStateService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

@layout UserLayout

<style>
    .chat-bubble-user {
        background: #0d6efd; color: #fff;
        border-radius: 18px 18px 4px 18px;
        max-width: 70%; padding: 10px 15px;
        word-break: break-word;
    }
    .chat-bubble-ai {
        background: #fff; color: #212529;
        border-radius: 18px 18px 18px 4px;
        max-width: 75%; padding: 10px 15px;
        border: 1px solid #dee2e6;
        word-break: break-word;
    }
    .bubble-row-user { display: flex; justify-content: flex-end; }
    .bubble-row-ai   { display: flex; justify-content: flex-start; }
    .chat-window {
        height: calc(100vh - 220px);
        min-height: 300px;
        overflow-y: auto;
        background: #f8f9fa;
        border-radius: 12px;
        padding: 16px;
    }
    @@media (max-width: 767.98px) {
        .chat-window { height: calc(100svh - 230px); min-height: 200px; }
        .chat-bubble-user, .chat-bubble-ai { max-width: 85%; }
    }
    .typing-indicator span {
        display: inline-block; width: 8px; height: 8px;
        border-radius: 50%; background: #6c757d;
        margin: 0 2px;
        animation: bounce 1.2s infinite ease-in-out;
    }
    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes bounce {
        0%, 80%, 100% { transform: scale(0); }
        40% { transform: scale(1); }
    }
</style>

@if (_toastMessage != null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show align-items-center text-white bg-primary border-0 shadow" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-robot me-2"></i> @_toastMessage
                    @if (_toastThreadId > 0)
                    {
                        <a href="chat/@_toastThreadId" class="text-white fw-bold ms-2">View →</a>
                    }
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        @onclick="() => { _toastMessage = null; _toastThreadId = 0; }"></button>
            </div>
        </div>
    </div>
}

<div class="d-flex flex-column h-100">
    <!-- Header -->
    <div class="mb-3">
        <h5 class="mb-0 fw-semibold">
            <i class="bi bi-chat-dots text-primary me-2"></i>
            @(logs.FirstOrDefault()?.Thread?.ThreadName ?? "New Conversation")
        </h5>
    </div>

    <!-- Messages -->
    <div class="chat-window flex-grow-1 mb-3" @ref="chatContainer">
        @if (!logs.Any() && !isThinking)
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-chat-heart" style="font-size:3rem; opacity:.3;"></i>
                <p class="mt-2">Start a conversation!</p>
            </div>
        }

        @foreach (var log in logs)
        {
            @if (log.IsReply)
            {
                <div class="bubble-row-ai mb-3">
                    <div class="me-2 mt-1 flex-shrink-0">
                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center"
                             style="width:32px;height:32px;">
                            <i class="bi bi-robot text-white" style="font-size:.75rem;"></i>
                        </div>
                    </div>
                    <div class="d-flex flex-column">
                        <div class="chat-bubble-ai">@log.Text</div>
                        <small class="text-muted mt-1 ms-1" style="font-size:0.7rem;">@FormatTime(log.EntryTime)</small>
                    </div>
                </div>
            }
            else
            {
                <div class="bubble-row-user mb-3">
                    <div class="d-flex flex-column align-items-end">
                        <div class="chat-bubble-user">@log.Text</div>
                        <small class="text-muted mt-1 me-1" style="font-size:0.7rem;">@FormatTime(log.EntryTime)</small>
                    </div>
                </div>
            }
        }

        @if (isThinking)
        {
            <div class="d-flex mb-3 justify-content-start">
                <div class="me-2 mt-1">
                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center"
                         style="width:32px;height:32px;">
                        <i class="bi bi-robot text-white" style="font-size:.75rem;"></i>
                    </div>
                </div>
                <div class="chat-bubble-ai">
                    <div class="typing-indicator">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Input -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-2">
            <div class="input-group">
                <textarea class="form-control border-0 resize-none"
                          rows="2"
                          placeholder="Type your message..."
                          @bind="inputText"
                          @bind:event="oninput"
                          @onkeydown="HandleKeyDown"
                          disabled="@isThinking"
                          style="resize:none;">
                </textarea>
                <button class="btn btn-primary px-4" @onclick="SendMessage" disabled="@isThinking">
                    @if (isThinking)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    else
                    {
                        <i class="bi bi-send-fill"></i>
                    }
                </button>
            </div>
            <small class="text-muted ms-1">Press Ctrl+Enter to send</small>
        </div>
    </div>
</div>

<script>
    function scrollToBottom(element) {
        if (element) element.scrollTop = element.scrollHeight;
    }
</script>

@implements IDisposable

@code {
    [Parameter] public int ThreadId { get; set; } = 0;

    private List<ChatLog> logs = new();
    private string inputText = string.Empty;
    private int userId;
    private ElementReference chatContainer;
    private bool isThinking;
    private bool _isSending;
    private int _loadedThreadId = -1;
    private int _selfNavToThreadId = -1;
    private string? _toastMessage;
    private int _toastThreadId;

    protected override void OnInitialized()
    {
        userId = AuthStateService.CurrentUser?.UserId ?? 0;
        AuthStateService.OnAuthStateChanged += OnAuthRestored;
        _pendingTracker.OnAiResponded += OnAiRespondedElsewhere;
    }

    private void OnAuthRestored()
    {
        var newUserId = AuthStateService.CurrentUser?.UserId ?? 0;
        if (newUserId != 0 && userId == 0)
        {
            userId = newUserId;
            _loadedThreadId = -1; // force reload
            InvokeAsync(async () =>
            {
                await OnParametersSetAsync();
                StateHasChanged();
            });
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Runs on initial load AND whenever ThreadId route parameter changes
        if (_loadedThreadId == ThreadId) return;
        _loadedThreadId = ThreadId;

        // Only skip reset if THIS navigation was triggered by our own first-send NavigateTo
        bool isSelfNavigation = _isSending && ThreadId == _selfNavToThreadId;
        _selfNavToThreadId = -1;

        if (!isSelfNavigation)
        {
            // User manually navigated — reset everything so new thread loads cleanly
            logs = new List<ChatLog>();
            inputText = string.Empty;
            isThinking = _pendingTracker.IsPending(ThreadId); // restore indicator if AI still running
            _isSending = isThinking;
        }

        var template = await _promptSettingService.GetActiveTemplateForUserAsync(userId);
        var systemPrompt = template?.Content ?? FamilyAI.Infrastructure.configuration.PromptTemplates.Educational;

        if (ThreadId != 0)
        {
            logs = await _chatLogService.GetChatLogsByThreadAsync(ThreadId);
        }

        await _aiChatService.InitializeAsync(systemPrompt, logs);
    }

    private void OnAiRespondedElsewhere(int threadId, string threadName)
    {
        if (threadId == ThreadId) return; // same thread, no toast needed
        InvokeAsync(() =>
        {
            _toastMessage = $"AI replied in \"{threadName}\"";
            _toastThreadId = threadId;
            StateHasChanged();
            // Auto-dismiss after 8 seconds
            _ = Task.Delay(8000).ContinueWith(_ => InvokeAsync(() =>
            {
                _toastMessage = null;
                _toastThreadId = 0;
                StateHasChanged();
            }));
        });
    }

    public void Dispose()
    {
        AuthStateService.OnAuthStateChanged -= OnAuthRestored;
        _pendingTracker.OnAiResponded -= OnAiRespondedElsewhere;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JSRuntime.InvokeVoidAsync("scrollToBottom", chatContainer);
    }

    private string FormatTime(DateTime utcTime)
    {
        var local = utcTime.ToLocalTime();
        return local.Date == DateTime.Today
            ? local.ToString("h:mm tt")
            : local.ToString("MMM d, h:mm tt");
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && e.CtrlKey)
            await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(inputText) || isThinking) return;

        var messageText = inputText.Trim();
        inputText = string.Empty;
        _isSending = true;
        isThinking = true;

        var userLog = new ChatLog
        {
            UserId = userId, ThreadId = ThreadId,
            Text = messageText, IsReply = false,
            EntryTime = DateTime.UtcNow, IsDeleted = false
        };

        var savedUserLog = await _chatLogService.AddChatLogAsync(userLog);

        if (ThreadId == 0)
        {
            ThreadId = savedUserLog.ThreadId;
            _selfNavToThreadId = ThreadId; // mark so OnParametersSetAsync skips reset
            NavigationManager.NavigateTo($"chat/{ThreadId}", false);
        }

        logs.Add(savedUserLog);
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("scrollToBottom", chatContainer);

        // Run AI call in background so the circuit stays responsive for navigation/clicks
        var capturedThreadId = ThreadId;
        var capturedUserId = userId;
        var capturedThreadName = logs.FirstOrDefault(l => l.Thread?.ThreadName != null)?.Thread?.ThreadName
                                 ?? $"Chat #{capturedThreadId}";
        _pendingTracker.SetPending(capturedThreadId, capturedThreadName);

        _ = Task.Run(async () =>
        {
            ChatLog? aiLog = null;
            try
            {
                var aiResponse = await _aiChatService.ChatWithAIAsync(messageText);
                aiLog = await _chatLogService.AddChatLogAsync(capturedUserId, capturedThreadId, aiResponse, isReply: true);
            }
            catch { }

            _pendingTracker.SetResponded(capturedThreadId); // fires toast if user is on different thread

            await InvokeAsync(async () =>
            {
                // If user navigated to a different thread, don't pollute the current view
                if (ThreadId != capturedThreadId)
                {
                    _isSending = false;
                    isThinking = false;
                    return;
                }
                logs.Add(aiLog ?? new ChatLog
                {
                    UserId = capturedUserId, ThreadId = capturedThreadId,
                    Text = "Sorry, I couldn't connect to the AI right now. Please try again.",
                    IsReply = true, EntryTime = DateTime.UtcNow, IsDeleted = false
                });
                _isSending = false;
                isThinking = false;
                StateHasChanged();
                await JSRuntime.InvokeVoidAsync("scrollToBottom", chatContainer);
            });
        });
    }
}
